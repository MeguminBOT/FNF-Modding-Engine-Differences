<!DOCTYPE codename-engine-stage>
<stage zoom="0.9" name="myStage" folder="stages/myStage">
    <!-- Background (furthest back) -->
    <sprite name="bg" x="-600" y="-200" sprite="stageback"
            scroll="0.9" scale="1" antialiasing="true" />

    <!-- Girlfriend (between background and foreground) -->
    <!-- Valid tags: <girlfriend>, <gf> -->
    <gf x="400" y="130" />

    <!-- Opponent -->
    <!-- Valid tags: <dad>, <opponent> -->
    <opponent x="100" y="100" />

    <!-- Stage floor -->
    <sprite name="front" x="-650" y="600" sprite="stagefront"
            scroll="0.9" scale="1.1" antialiasing="true" />

    <!-- Player -->
    <!-- Valid tags: <boyfriend>, <bf>, <player> -->
    <player x="770" y="100" />

    <!-- Foreground curtains (closest to camera) -->
    <sprite name="curtains" x="-500" y="-300" sprite="stagecurtains"
            scroll="1.3" scale="0.9" antialiasing="true" />
</stage>
