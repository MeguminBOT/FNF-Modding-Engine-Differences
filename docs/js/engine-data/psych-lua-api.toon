callbacks:
    lifecycle[5]:
        - name: onCreate
            params[0]:
            notes: "Script loaded, after variables set"
        - name: onCreatePost
            params[0]:
            notes: After everything created
        - name: onUpdate
            params[1]: "elapsed:Float"
            notes: Every frame
        - name: onUpdatePost
            params[1]: "elapsed:Float"
            notes: After updates
        - name: onDestroy
            params[0]:
            notes: State destroyed
    song[5]:
        - name: onStartCountdown
            params[0]:
            notes: Before countdown. Return false to cancel
            cancellable: true
        - name: onCountdownStarted
            params[0]:
            notes: Countdown actually began
        - name: onCountdownTick
            params[1]: "swagCounter:Int"
            notes: Each countdown tick
        - name: onSongStart
            params[0]:
            notes: Song begins playing
        - name: onEndSong
            params[0]:
            notes: Song completed. Return false to cancel
            cancellable: true
    timing[3]:
        - name: onStepHit
            params[0]:
            notes: Each step hit. curStep via global
        - name: onBeatHit
            params[0]:
            notes: Each beat hit. curBeat via global
        - name: onSectionHit
            params[0]:
            notes: Section boundary crossed
    notes[7]:
        - name: onSpawnNote
            params[5]: "membersIndex:Int","noteData:Int","noteType:String","isSustainNote:Bool","strumTime:Float"
            notes: Note spawned
        - name: goodNoteHitPre
            params[4]: "membersIndex:Int","noteData:Int","noteType:String","isSustainNote:Bool"
            notes: Before player hit
        - name: goodNoteHit
            params[4]: "membersIndex:Int","noteData:Int","noteType:String","isSustainNote:Bool"
            notes: Player hit note
        - name: opponentNoteHitPre
            params[4]: "membersIndex:Int","noteData:Int","noteType:String","isSustainNote:Bool"
            notes: Before opponent hit
        - name: opponentNoteHit
            params[4]: "membersIndex:Int","noteData:Int","noteType:String","isSustainNote:Bool"
            notes: Opponent hit note
        - name: noteMiss
            params[4]: "membersIndex:Int","noteData:Int","noteType:String","isSustainNote:Bool"
            notes: Note missed
        - name: noteMissPress
            params[1]: "direction:Int"
            notes: Pressed key with no notes (ghost miss)
    input[5]:
        - name: onKeyPressPre
            params[1]: "key:Int"
            notes: "Before key pressed, return to block"
        - name: onKeyPress
            params[1]: "key:Int"
            notes: Key pressed
        - name: onKeyReleasePre
            params[1]: "key:Int"
            notes: Before key released
        - name: onKeyRelease
            params[1]: "key:Int"
            notes: Key released
        - name: onGhostTap
            params[1]: "key:Int"
            notes: Key pressed with no notes
    events[3]:
        - name: onEvent
            params[4]: "eventName:String","value1:String","value2:String","strumTime:Float"
            notes: Event triggered
        - name: onEventPushed
            params[4]: "eventName:String","value1:String","value2:String","strumTime:Float"
            notes: Event loaded from chart
        - name: eventEarlyTrigger
            params[4]: "eventName:String","value1:String","value2:String","strumTime:Float"
            notes: Return Float to offset trigger time
    camera[1]:
        - name: onMoveCamera
            params[1]: "character:String"
            notes: Camera moved to character (dad/gf/boyfriend)
    pause_gameover[7]:
        - name: onPause
            params[0]:
            notes: Before pause. Return false to cancel
            cancellable: true
        - name: onResume
            params[0]:
            notes: After resume
        - name: onGameOver
            params[0]:
            notes: Before game over. Return false to cancel
            cancellable: true
        - name: onGameOverStart
            params[0]:
            notes: Game over state entered
        - name: onGameOverUpdate
            params[1]: "elapsed:Float"
            notes: Game over frame
        - name: onGameOverUpdatePost
            params[1]: "elapsed:Float"
            notes: After game over update
        - name: onGameOverConfirm
            params[1]: "returnToMenu:Bool"
            notes: Exit confirmed
    dialogue[2]:
        - name: onNextDialogue
            params[1]: "dialogueCount:Int"
            notes: Next dialogue line
        - name: onSkipDialogue
            params[1]: "dialogueCount:Int"
            notes: Dialogue skipped
    rating[2]:
        - name: onRecalculateRating
            params[0]:
            notes: Before rating recalculated
        - name: onUpdateScore
            params[1]: "miss:Bool"
            notes: Score updated
    tween_timer[3]:
        - name: onTweenCompleted
            params[2]: "tag:String","vars:String"
            notes: Tween finished
        - name: onTimerCompleted
            params[3]: "tag:String","loops:Int","loopsLeft:Int"
            notes: Timer finished
        - name: onSoundFinished
            params[1]: "tag:String"
            notes: Sound finished
    custom_substates[5]:
        - name: onCustomSubstateCreate
            params[1]: "name:String"
            notes: Substate created
        - name: onCustomSubstateCreatePost
            params[1]: "name:String"
            notes: After substate created
        - name: onCustomSubstateUpdate
            params[2]: "name:String","elapsed:Float"
            notes: Substate update
        - name: onCustomSubstateUpdatePost
            params[2]: "name:String","elapsed:Float"
            notes: After substate update
        - name: onCustomSubstateDestroy
            params[1]: "name:String"
            notes: Substate destroyed
hscript:
    availableClasses[24]: Type,File,FileSystem,FlxG,FlxMath,FlxSprite,FlxText,FlxCamera,PsychCamera,FlxTimer,FlxTween,FlxEase,FlxColor,PlayState,Paths,Conductor,ClientPrefs,Character,Alphabet,Note,CustomSubstate,FlxRuntimeShader,StringTools,FlxAnimate
    functions:
        setVar:
            params[2]: "name:String","value:Dynamic"
            returns: Dynamic
        getVar:
            params[1]: "name:String"
            returns: Dynamic
        removeVar:
            params[1]: "name:String"
            returns: Bool
        debugPrint:
            params[2]: "text:String","?color:FlxColor"
            returns: Void
        getModSetting:
            params[2]: "saveTag:String","?modName:String"
            returns: Dynamic
        addHaxeLibrary:
            params[2]: "libName:String","?libPackage:String"
            returns: Void
        createGlobalCallback:
            params[2]: "name:String","func:Dynamic"
            returns: Void
        createCallback:
            params[3]: "name:String","func:Dynamic",?funk
            returns: Void
    luaBridge:
        runHaxeCode:
            params[4]: "codeToRun:String","?varsToBring:Any","?funcToRun:String","?funcArgs:Array<Dynamic>"
            returns: Dynamic
        runHaxeFunction:
            params[2]: "funcToRun:String","?funcArgs:Array<Dynamic>"
            returns: Dynamic
