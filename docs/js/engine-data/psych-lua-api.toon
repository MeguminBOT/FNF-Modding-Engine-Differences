        Function_Stop: String
        Function_Continue: String
    debug:
        luaDebugMode: "Bool (default: false)"
        luaDeprecatedWarnings: "Bool (default: true)"
    song_data:
        curBpm: Float
        bpm: Float
        scrollSpeed: Float
        crochet: Float
