{
  "version": "1.0.0",
  "description": "Cross-engine callback/event mapping for FNF script conversion",
  "mappings": {
    "lifecycle": {
      "onCreate": {
        "psych": { "callback": "onCreate", "timing": "Script init, after variables set" },
        "codename": { "callback": "create", "timing": "State create()" },
        "official": { "callback": "onCreate", "timing": "ScriptEvent.CREATE dispatched", "eventType": "ScriptEvent" }
      },
      "onCreatePost": {
        "psych": { "callback": "onCreatePost", "timing": "After create() completes" },
        "codename": { "callback": "postCreate", "timing": "After create()" },
        "official": { "callback": "onCreatePost", "timing": "After create completes", "eventType": "ScriptEvent" }
      },
      "onUpdate": {
        "psych": { "callback": "onUpdate", "params": ["elapsed:Float"], "timing": "Each frame" },
        "codename": { "callback": "update", "params": ["elapsed:Float"], "timing": "Each frame" },
        "official": { "callback": "onUpdate", "timing": "UpdateScriptEvent", "eventType": "UpdateScriptEvent", "eventFields": ["elapsed:Float"] }
      },
      "onUpdatePost": {
        "psych": { "callback": "onUpdatePost", "params": ["elapsed:Float"], "timing": "After update()" },
        "codename": { "callback": "postUpdate", "params": ["elapsed:Float"], "timing": "After update()" },
        "official": { "callback": "onUpdatePost", "eventType": "UpdateScriptEvent" }
      },
      "onDestroy": {
        "psych": { "callback": "onDestroy", "timing": "State destroy" },
        "codename": { "callback": "destroy", "timing": "State destroy" },
        "official": { "callback": "onDestroy", "timing": "ScriptEvent.DESTROY", "eventType": "ScriptEvent" }
      },
      "onDraw": {
        "psych": null,
        "codename": { "callback": "draw", "timing": "Each frame draw" },
        "official": null
      }
    },

    "song_lifecycle": {
      "onSongStart": {
        "psych": { "callback": "onSongStart", "timing": "After countdown, song begins" },
        "codename": { "callback": "onSongStart", "timing": "Song starts playing" },
        "official": { "callback": "onSongStart", "eventType": "ScriptEvent" }
      },
      "onEndSong": {
        "psych": { "callback": "onEndSong", "timing": "Song completed", "cancellable": true },
        "codename": { "callback": "onSongEnd", "timing": "Song completed" },
        "official": { "callback": "onSongEnd", "eventType": "ScriptEvent" }
      },
      "onStartCountdown": {
        "psych": { "callback": "onStartCountdown", "timing": "Before countdown begins", "cancellable": true },
        "codename": { "callback": "onStartCountdown", "timing": "Before countdown", "cancellable": true },
        "official": { "callback": "onCountdownStart", "eventType": "CountdownScriptEvent", "cancellable": true }
      },
      "onCountdownTick": {
        "psych": { "callback": "onCountdownTick", "params": ["counter:Int"], "timing": "Each countdown tick" },
        "codename": { "callback": "onCountdown", "timing": "Each tick", "eventType": "CountdownEvent", "eventFields": ["swagCounter:Int"] },
        "official": { "callback": "onCountdownStep", "eventType": "CountdownScriptEvent", "eventFields": ["step:Int"] }
      },
      "onCountdownEnd": {
        "psych": null,
        "codename": null,
        "official": { "callback": "onCountdownEnd", "eventType": "CountdownScriptEvent" }
      },
      "onCountdownStarted": {
        "psych": { "callback": "onCountdownStarted", "timing": "After countdown has been started" },
        "codename": null,
        "official": null
      }
    },

    "beat_and_step": {
      "onBeatHit": {
        "psych": { "callback": "onBeatHit", "access": "curBeat via global" },
        "codename": { "callback": "beatHit", "params": ["beat:Int"], "alternateAccess": "Also via Conductor signal" },
        "official": { "callback": "onBeatHit", "eventType": "SongTimeScriptEvent", "eventFields": ["beat:Int", "step:Int"] }
      },
      "onStepHit": {
        "psych": { "callback": "onStepHit", "access": "curStep via global" },
        "codename": { "callback": "stepHit", "params": ["step:Int"], "alternateAccess": "Also via Conductor signal" },
        "official": { "callback": "onStepHit", "eventType": "SongTimeScriptEvent", "eventFields": ["beat:Int", "step:Int"] }
      },
      "onSectionHit": {
        "psych": { "callback": "onSectionHit", "timing": "When a chart section boundary is crossed" },
        "codename": { "callback": "measureHit", "params": ["measure:Int"], "notes": "Called per measure, not section" },
        "official": null
      }
    },

    "note_events": {
      "goodNoteHit": {
        "psych": { "callback": "goodNoteHit", "params": ["membersIndex:Int", "noteData:Int", "noteType:String", "isSustainNote:Bool"] },
        "codename": { "callback": "onNoteHit", "eventType": "NoteHitEvent", "eventFields": ["note:Note", "rating:String", "score:Int", "character:Character", "strumLine:StrumLine", "animSuffix:String", "healthGain:Float", "showRating:Bool", "showSplash:Bool"], "cancellable": true },
        "official": { "callback": "onNoteHit", "eventType": "HitNoteScriptEvent", "eventFields": ["note:NoteSprite", "judgement:String", "score:Int", "healthChange:Float", "comboCount:Int", "isComboBreak:Bool", "hitDiff:Float", "doesNotesplash:Bool", "playSound:Bool"] }
      },
      "opponentNoteHit": {
        "psych": { "callback": "opponentNoteHit", "params": ["membersIndex:Int", "noteData:Int", "noteType:String", "isSustainNote:Bool"] },
        "codename": { "callback": "onNoteHit", "notes": "Same callback, differentiate by event.strumLine.opponentSide" },
        "official": { "callback": "onNoteHit", "notes": "Same callback, differentiate by note ownership" }
      },
      "noteMiss": {
        "psych": { "callback": "noteMiss", "params": ["membersIndex:Int", "noteData:Int", "noteType:String", "isSustainNote:Bool"] },
        "codename": { "callback": "onNoteMiss", "eventType": "NoteMissEvent", "eventFields": ["note:Note", "direction:Int", "character:Character", "strumLine:StrumLine", "healthLoss:Float", "playAnim:Bool", "score:Int"], "cancellable": true },
        "official": { "callback": "onNoteMiss", "eventType": "NoteScriptEvent", "eventFields": ["note:NoteSprite"] }
      },
      "noteMissPress": {
        "psych": { "callback": "noteMissPress", "params": ["direction:Int"], "notes": "Ghost miss (pressed wrong key)" },
        "codename": { "callback": "onNoteMiss", "notes": "Same event with note=null" },
        "official": { "callback": "onNoteGhostMiss", "eventType": "GhostMissNoteScriptEvent" }
      },
      "onSpawnNote": {
        "psych": { "callback": "onSpawnNote", "params": ["membersIndex:Int", "noteData:Int", "noteType:String", "isSustainNote:Bool", "strumTime:Float"] },
        "codename": { "callback": "onNoteSpawn", "eventType": "NoteSpawnEvent" },
        "official": null
      },
      "goodNoteHitPre": {
        "psych": { "callback": "goodNoteHitPre", "params": ["membersIndex:Int", "noteData:Int", "noteType:String", "isSustainNote:Bool"], "cancellable": true },
        "codename": null,
        "official": null
      },
      "opponentNoteHitPre": {
        "psych": { "callback": "opponentNoteHitPre", "params": ["membersIndex:Int", "noteData:Int", "noteType:String", "isSustainNote:Bool"], "cancellable": true },
        "codename": null,
        "official": null
      },
      "onNoteIncoming": {
        "psych": null,
        "codename": null,
        "official": { "callback": "onNoteIncoming", "eventType": "NoteScriptEvent", "eventFields": ["note:NoteSprite"], "cancellable": true }
      },
      "onNoteHoldDrop": {
        "psych": null,
        "codename": null,
        "official": { "callback": "onNoteHoldDrop", "eventType": "HoldNoteScriptEvent", "eventFields": ["note:NoteSprite", "holdNote:SustainTrail"], "cancellable": true }
      }
    },

    "input": {
      "onKeyPress": {
        "psych": { "callback": "onKeyPress", "params": ["key:Int"] },
        "codename": { "callback": "onKeyPress", "params": ["key:Int"] },
        "official": null
      },
      "onKeyRelease": {
        "psych": { "callback": "onKeyRelease", "params": ["key:Int"] },
        "codename": { "callback": "onKeyRelease", "params": ["key:Int"] },
        "official": null
      },
      "onGhostTap": {
        "psych": { "callback": "onGhostTap", "params": ["key:Int"] },
        "codename": { "callback": "onGhostTap", "params": ["key:Int"] },
        "official": null
      }
    },

    "events": {
      "onEvent": {
        "psych": { "callback": "onEvent", "params": ["eventName:String", "value1:String", "value2:String", "strumTime:Float"] },
        "codename": { "callback": "onEvent", "eventType": "SongEvent", "notes": "Song events are separate system" },
        "official": { "callback": "onSongEvent", "eventType": "SongEventScriptEvent", "eventFields": ["eventData:SongEventData"] }
      },
      "onEventPushed": {
        "psych": { "callback": "onEventPushed", "params": ["eventName:String", "value1:String", "value2:String", "strumTime:Float"] },
        "codename": null,
        "official": null
      }
    },

    "camera": {
      "onMoveCamera": {
        "psych": { "callback": "onMoveCamera", "params": ["character:String"], "notes": "character is 'boyfriend','dad','gf'" },
        "codename": null,
        "official": null
      },
      "isCameraOnForcedPos": {
        "psych": { "variable": "isCameraOnForcedPos", "type": "Bool" },
        "codename": null,
        "official": null
      }
    },

    "pause_and_gameover": {
      "onPause": {
        "psych": { "callback": "onPause", "cancellable": true },
        "codename": { "callback": "onPause", "cancellable": true },
        "official": { "callback": "onPause", "eventType": "PauseScriptEvent", "cancellable": true }
      },
      "onResume": {
        "psych": { "callback": "onResume" },
        "codename": { "callback": "onResume" },
        "official": { "callback": "onResume", "eventType": "ScriptEvent" }
      },
      "onGameOver": {
        "psych": { "callback": "onGameOver", "cancellable": true },
        "codename": { "callback": "onGameOver", "eventType": "GameOverEvent", "cancellable": true },
        "official": { "callback": "onGameOver", "eventType": "ScriptEvent", "cancellable": true }
      },
      "onSongRetry": {
        "psych": null,
        "codename": null,
        "official": { "callback": "onSongRetry", "eventType": "SongRetryEvent", "cancellable": true }
      }
    },

    "dialogue": {
      "onNextDialogue": {
        "psych": { "callback": "onNextDialogue", "params": ["dialogueCount:Int"] },
        "codename": { "callback": "onDialogueLine", "notes": "Dialogue events from DialogueBoxState" },
        "official": { "callback": "onDialogueStart", "eventType": "DialogueScriptEvent" }
      },
      "onSkipDialogue": {
        "psych": { "callback": "onSkipDialogue", "params": ["dialogueCount:Int"] },
        "codename": null,
        "official": null
      }
    },

    "rating": {
      "onRecalculateRating": {
        "psych": { "callback": "onRecalculateRating", "cancellable": true },
        "codename": null,
        "official": null
      }
    },

    "score": {
      "preUpdateScore": {
        "psych": { "callback": "preUpdateScore", "params": ["miss:Bool"], "cancellable": true },
        "codename": null,
        "official": null
      },
      "onUpdateScore": {
        "psych": { "callback": "onUpdateScore", "params": ["miss:Bool"] },
        "codename": null,
        "official": null
      }
    },

    "timing_and_tweens": {
      "onTweenCompleted": {
        "psych": { "callback": "onTweenCompleted", "params": ["tag:String", "vars:Dynamic"] },
        "codename": null,
        "official": null
      },
      "onTimerCompleted": {
        "psych": { "callback": "onTimerCompleted", "params": ["tag:String", "loops:Int", "loopsLeft:Int"] },
        "codename": null,
        "official": null
      },
      "onSoundFinished": {
        "psych": { "callback": "onSoundFinished", "params": ["tag:String"] },
        "codename": null,
        "official": null
      }
    },

    "custom_substates": {
      "onCustomSubstateCreate": {
        "psych": { "callback": "onCustomSubstateCreate", "params": ["name:String"] },
        "codename": null,
        "official": null
      },
      "onCustomSubstateCreatePost": {
        "psych": { "callback": "onCustomSubstateCreatePost", "params": ["name:String"] },
        "codename": null,
        "official": null
      },
      "onCustomSubstateUpdate": {
        "psych": { "callback": "onCustomSubstateUpdate", "params": ["name:String", "elapsed:Float"] },
        "codename": null,
        "official": null
      },
      "onCustomSubstateDestroy": {
        "psych": { "callback": "onCustomSubstateDestroy", "params": ["name:String"] },
        "codename": null,
        "official": null
      }
    }
  }
}
