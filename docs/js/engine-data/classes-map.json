    "Character": {
      "psych": {
        "package": "objects",
        "class": "Character",
        "file": "source/objects/Character.hx",
        "fields": {
          "curCharacter": "String", "isPlayer": "Bool", "healthIcon": "String",
          "animationsArray": "Array<AnimArray>", "singDuration": "Float",
          "positionArray": "Array<Float>", "cameraPosition": "Array<Float>",
          "healthColorArray": "Array<Int>", "danceIdle": "Bool", "idleSuffix": "String"
        }
      },
      "codename": {
        "package": "funkin.game",
        "class": "Character",
        "file": "source/funkin/game/Character.hx",
        "fields": {
          "curCharacter": "String", "isPlayer": "Bool", "icon": "String",
          "iconColor": "Null<FlxColor>", "holdTime": "Float", "danceOnBeat": "Bool",
          "idleSuffix": "String", "cameraOffset": "FlxPoint", "globalOffset": "FlxPoint",
          "gameOverCharacter": "String", "xml": "Access"
        }
      },
      "official": {
        "package": "funkin.play.character",
        "class": "BaseCharacter",
        "file": "source/funkin/play/character/BaseCharacter.hx",
        "scriptedClass": "ScriptedCharacter",
        "fields": {
          "characterId": "String", "characterName": "String",
          "characterType": "CharacterType", "holdTimer": "Float",
          "isDead": "Bool", "cameraFocusPoint": "FlxPoint"
        },
        "methods": {
          "playAnimation": ["name:String", "force:Bool"],
          "singNote": ["direction:NoteDirection", "length:Float"],
          "holdNote": ["direction:NoteDirection"],
          "playDeath": [],
          "resetCharacter": ["resetAnimations:Bool"]
        }
      }
    },

    "Note": {
      "psych": {
        "package": "objects",
        "class": "Note",
        "file": "source/objects/Note.hx",
        "fields": {
          "strumTime": "Float", "noteData": "Int", "mustPress": "Bool",
          "isSustainNote": "Bool", "sustainLength": "Float", "noteType": "String",
          "canBeHit": "Bool", "wasGoodHit": "Bool", "missed": "Bool",
          "gfNote": "Bool", "noAnimation": "Bool",
          "hitHealth": "Float", "missHealth": "Float", "texture": "String"
        }
      },
      "codename": {
        "package": "funkin.game",
        "class": "Note",
        "file": "source/funkin/game/Note.hx",
        "fields": {
          "strumTime": "Float", "noteData": "Int", "mustPress": "Bool (getter)",
          "isSustainNote": "Bool", "sustainLength": "Float", "noteType": "String (getter)",
          "canBeHit": "Bool", "wasGoodHit": "Bool", "tooLate": "Bool",
          "strumLine": "StrumLine", "strumID": "Int (getter)", "animSuffix": "String",
          "extra": "Map<String,Dynamic>", "prevNote": "Note", "nextNote": "Note"
        }
      },
      "official": {
        "package": "funkin.play.notes",
        "class": "NoteSprite",
        "file": "source/funkin/play/notes/NoteSprite.hx",
        "fields": {
          "strumTime": "Float", "direction": "NoteDirection", "length": "Float",
          "kind": "Null<String>", "noteData": "SongNoteData",
          "isHoldNote": "Bool (computed)", "scoreable": "Bool",
          "hasBeenHit": "Bool", "hasMissed": "Bool"
        }
      }
    },

    "Strumline": {
      "psych": {
        "package": "objects",
        "class": "StrumNote",
        "file": "source/objects/StrumNote.hx",
        "notes": "Individual strum receptor. Group accessed via playerStrums/opponentStrums on PlayState",
        "fields": {
          "noteData": "Int", "direction": "Float", "downScroll": "Bool",
          "resetAnim": "Float", "texture": "String"
        }
      },
      "codename": {
        "package": "funkin.game",
        "class": "StrumLine",
        "file": "source/funkin/game/StrumLine.hx",
        "notes": "Full strum line group with notes, characters, and signals",
        "fields": {
          "characters": "Array<Character>", "cpu": "Bool", "opponentSide": "Bool",
          "notes": "NoteGroup", "controls": "Controls", "vocals": "FlxSound",
          "ghostTapping": "Null<Bool>", "strumScale": "Float"
        },
        "signals": {
          "onHit": "FlxTypedSignal<NoteHitEvent->Void>",
          "onMiss": "FlxTypedSignal<NoteMissEvent->Void>"
        }
      },
      "official": {
        "package": "funkin.play.notes",
        "class": "Strumline",
        "file": "source/funkin/play/notes/Strumline.hx",
        "fields": {
          "isPlayer": "Bool", "scrollSpeed": "Float",
          "notes": "FlxTypedSpriteGroup<NoteSprite>",
          "holdNotes": "FlxTypedSpriteGroup<SustainTrail>",
          "strumlineNotes": "FlxTypedSpriteGroup<StrumlineNote>"
        },
        "constants": {
          "KEY_COUNT": 4, "STRUMLINE_SIZE": 104, "NOTE_SPACING": 112
        }
      }
    },

