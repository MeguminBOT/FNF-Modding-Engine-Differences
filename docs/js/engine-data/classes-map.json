        "package": "funkin.menus",
        "class": "PauseSubState",
        "file": "source/funkin/menus/PauseSubState.hx"
      },
      "official": {
        "package": "funkin.play",
        "class": "PauseSubState",
        "file": "source/funkin/play/PauseSubState.hx"
      }
    },

    "Song": {
      "psych": {
        "package": "backend",
        "class": "Song",
        "file": "source/backend/Song.hx",
        "typedef": "SwagSong",
        "fields": {
          "song": "String", "notes": "Array<SwagSection>", "events": "Array<Dynamic>",
          "bpm": "Float", "needsVoices": "Bool", "speed": "Float", "offset": "Float",
          "player1": "String", "player2": "String", "gfVersion": "String", "stage": "String"
        }
      },
      "codename": {
        "package": "funkin.backend.chart",
        "class": "ChartData",
        "file": "source/funkin/backend/chart/",
        "notes": "Chart data is parsed from various formats into ChartData"
