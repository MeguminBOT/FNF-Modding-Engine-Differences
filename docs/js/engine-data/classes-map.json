{
  "version": "1.0.0",
  "description": "Cross-engine class equivalence mapping for FNF script conversion",
  "classes": {
    "Conductor": {
      "psych": {
        "package": "backend",
        "class": "Conductor",
        "file": "source/backend/Conductor.hx",
        "access": "Conductor (static)",
        "fields": {
          "bpm": { "type": "Float", "static": true },
          "crochet": { "type": "Float", "static": true, "notes": "Beat duration in ms" },
          "stepCrochet": { "type": "Float", "static": true, "notes": "Step duration in ms" },
          "songPosition": { "type": "Float", "static": true },
          "offset": { "type": "Float", "static": true },
          "safeZoneOffset": { "type": "Float", "static": true },
          "bpmChangeMap": { "type": "Array<BPMChangeEvent>", "static": true }
        },
        "methods": {
          "judgeNote": { "params": ["arr:Array<Rating>", "diff:Float"], "returns": "Rating", "static": true },
          "beatToSeconds": { "params": ["beat:Float"], "returns": "Float", "static": true },
          "getStep": { "params": ["time:Float"], "returns": "Float", "static": true },
          "getBeat": { "params": ["time:Float"], "returns": "Float", "static": true },
          "mapBPMChanges": { "params": ["song:SwagSong"], "returns": "Void", "static": true }
        }
      },
      "codename": {
        "package": "funkin.backend.system",
        "class": "Conductor",
        "file": "source/funkin/backend/system/Conductor.hx",
        "access": "Conductor (static)",
        "fields": {
          "bpm": { "type": "Float", "static": true, "getter": true },
          "startingBPM": { "type": "Float", "static": true, "getter": true },
          "crochet": { "type": "Float", "static": true, "getter": true },
          "stepCrochet": { "type": "Float", "static": true, "getter": true },
          "songPosition": { "type": "Float", "static": true, "getter": true },
          "songOffset": { "type": "Float", "static": true },
          "curStepFloat": { "type": "Float", "static": true, "getter": true },
          "curBeatFloat": { "type": "Float", "static": true, "getter": true },
          "curMeasureFloat": { "type": "Float", "static": true, "getter": true },
          "beatsPerMeasure": { "type": "Float", "static": true, "getter": true },
          "stepsPerBeat": { "type": "Int", "static": true, "getter": true },
          "bpmChangeMap": { "type": "Array<BPMChangeEvent>", "static": true }
        },
        "methods": {
          "changeBPM": { "params": ["bpm:Float", "beatsPerMeasure:Float", "stepsPerBeat:Int"], "returns": "Void", "static": true },
          "setupSong": { "params": ["SONG:ChartData"], "returns": "Void", "static": true },
          "mapBPMChanges": { "params": ["song:ChartData"], "returns": "Void", "static": true },
          "reset": { "params": [], "returns": "Void", "static": true }
        },
        "signals": {
          "onMeasureHit": "FlxTypedSignal<Int->Void>",
          "onBeatHit": "FlxTypedSignal<Int->Void>",
          "onStepHit": "FlxTypedSignal<Int->Void>",
          "onBPMChange": "FlxTypedSignal<(Float,Float)->Void>",
          "onTimeSignatureChange": "FlxTypedSignal"
        }
      },
      "official": {
        "package": "funkin",
        "class": "Conductor",
        "file": "source/funkin/Conductor.hx",
        "access": "Conductor.instance",
        "fields": {
          "songPosition": { "type": "Float" },
          "bpm": { "type": "Float" },
          "beatLengthMs": { "type": "Float", "notes": "Equivalent to crochet" },
          "stepLengthMs": { "type": "Float", "notes": "Equivalent to stepCrochet" },
          "measureLengthMs": { "type": "Float" },
          "timeSignatureNum": { "type": "Int" },
          "timeSignatureDen": { "type": "Int" },
          "currentTimeChange": { "type": "SongTimeChange" }
        },
        "methods": {
          "update": { "params": ["songPosition:Float"], "returns": "Void" },
          "getTimeFromStep": { "params": ["step:Int"], "returns": "Float" },
          "getStepFromTime": { "params": ["time:Float"], "returns": "Int" },
          "forceBPM": { "params": ["bpm:Float"], "returns": "Void" },
          "clearForcedBPM": { "params": [], "returns": "Void" }
        },
        "notes": "Instance-based (not static). Access via Conductor.instance"
      }
    },

    "Paths": {
      "psych": {
        "package": "backend",
        "class": "Paths",
        "file": "source/backend/Paths.hx",
        "access": "Paths (static)",
        "methods": {
          "image": { "params": ["key:String", "?allowGPU:Bool"], "returns": "Dynamic" },
          "sound": { "params": ["key:String"], "returns": "Dynamic" },
          "music": { "params": ["key:String"], "returns": "Dynamic" },
          "getSparrowAtlas": { "params": ["key:String"], "returns": "FlxFramesCollection" },
          "getAtlas": { "params": ["key:String"], "returns": "FlxFramesCollection" },
          "json": { "params": ["key:String", "?folder:String"], "returns": "String" },
          "xml": { "params": ["key:String", "?folder:String"], "returns": "String" },
          "txt": { "params": ["key:String", "?folder:String"], "returns": "String" },
          "lua": { "params": ["key:String", "?folder:String"], "returns": "String" },
          "shaderFragment": { "params": ["key:String"], "returns": "String" },
          "shaderVertex": { "params": ["key:String"], "returns": "String" }
        },
        "constants": {
          "SOUND_EXT": "ogg (desktop) / mp3 (web)",
          "VIDEO_EXT": "mp4"
        }
      },
      "codename": {
        "package": "funkin.backend.assets",
        "class": "Paths",
        "file": "source/funkin/backend/assets/Paths.hx",
        "access": "Paths (static)",
        "methods": {
          "image": { "params": ["key:String", "?library:String", "?checkForAtlas:Bool", "?ext:String"], "returns": "String" },
          "sound": { "params": ["key:String", "?library:String", "?ext:String"], "returns": "String" },
          "music": { "params": ["key:String", "?library:String", "?ext:String"], "returns": "String" },
          "voices": { "params": ["song:String", "?difficulty:String", "?suffix:String", "?ext:String"], "returns": "String" },
          "inst": { "params": ["song:String", "?difficulty:String", "?suffix:String", "?ext:String"], "returns": "String" },
          "json": { "params": ["key:String", "?library:String"], "returns": "String" },
          "xml": { "params": ["key:String", "?library:String"], "returns": "String" },
          "txt": { "params": ["key:String", "?library:String"], "returns": "String" },
          "getSparrowAtlas": { "params": ["key:String", "?library:String", "?ext:String"], "returns": "FlxAtlasFrames" },
          "getPackerAtlas": { "params": ["key:String", "?library:String", "?ext:String"], "returns": "FlxAtlasFrames" },
          "getFrames": { "params": ["key:String", "?assetsPath:Bool", "?library:String"], "returns": "FlxFramesCollection" },
          "video": { "params": ["key:String", "?ext:String"], "returns": "String" },
          "script": { "params": ["key:String", "?library:String"], "returns": "String" },
          "character": { "params": ["character:String"], "returns": "String" },
          "chart": { "params": ["song:String", "?difficulty:String", "?variant:String"], "returns": "String" }
        }
      },
      "official": {
        "package": "funkin",
        "class": "Paths",
        "file": "source/funkin/Paths.hx",
        "access": "Paths (static)",
        "methods": {
          "image": { "params": ["key:String"], "returns": "String" },
          "sound": { "params": ["key:String"], "returns": "String" },
          "music": { "params": ["key:String"], "returns": "String" },
          "voices": { "params": ["song:String"], "returns": "String" },
          "inst": { "params": ["song:String"], "returns": "String" },
          "json": { "params": ["key:String"], "returns": "String" },
          "getSparrowAtlas": { "params": ["key:String"], "returns": "FlxAtlasFrames" },
          "animateAtlas": { "params": ["path:String"], "returns": "String" }
        }
      }
    },

    "PlayState": {
      "psych": {
        "package": "states",
        "class": "PlayState",
        "file": "source/states/PlayState.hx",
        "access": "PlayState.instance",
        "fields": {
          "SONG": { "type": "SwagSong", "static": true },
          "instance": { "type": "PlayState", "static": true },
          "isStoryMode": { "type": "Bool", "static": true },
          "storyDifficulty": { "type": "Int", "static": true },
          "health": { "type": "Float" },
          "combo": { "type": "Int" },
          "songScore": { "type": "Int" },
          "songMisses": { "type": "Int" },
          "songHits": { "type": "Int" },
          "boyfriend": { "type": "Character" },
          "dad": { "type": "Character" },
          "gf": { "type": "Character" },
          "boyfriendGroup": { "type": "FlxSpriteGroup" },
          "dadGroup": { "type": "FlxSpriteGroup" },
          "gfGroup": { "type": "FlxSpriteGroup" },
          "camGame": { "type": "FlxCamera" },
          "camHUD": { "type": "FlxCamera" },
          "camOther": { "type": "FlxCamera" },
          "playerStrums": { "type": "FlxTypedGroup<StrumNote>" },
          "opponentStrums": { "type": "FlxTypedGroup<StrumNote>" },
          "startedCountdown": { "type": "Bool" },
          "generatedMusic": { "type": "Bool" }
        }
      },
      "codename": {
        "package": "funkin.game",
        "class": "PlayState",
        "file": "source/funkin/game/PlayState.hx",
        "access": "PlayState.instance",
        "fields": {
          "SONG": { "type": "ChartData", "static": true },
          "instance": { "type": "PlayState", "static": true },
          "isStoryMode": { "type": "Bool", "static": true },
          "difficulty": { "type": "String", "static": true },
          "variation": { "type": "Null<String>", "static": true },
          "opponentMode": { "type": "Bool", "static": true },
          "coopMode": { "type": "Bool", "static": true },
          "health": { "type": "Float" },
          "maxHealth": { "type": "Float" },
          "combo": { "type": "Int" },
          "boyfriend": { "type": "Character", "getter": true },
          "dad": { "type": "Character", "getter": true },
          "gf": { "type": "Character", "getter": true },
          "bf": { "type": "Character", "getter": true, "notes": "Alias for boyfriend" },
          "strumLines": { "type": "FlxTypedGroup<StrumLine>" },
          "playerStrums": { "type": "StrumLine", "getter": true },
          "cpuStrums": { "type": "StrumLine", "getter": true },
          "player": { "type": "StrumLine", "getter": true },
          "cpu": { "type": "StrumLine", "getter": true },
          "stage": { "type": "Stage" },
          "scrollSpeed": { "type": "Float" },
          "downscroll": { "type": "Bool", "getter": true },
          "inst": { "type": "FlxSound" },
          "vocals": { "type": "FlxSound" },
          "iconP1": { "type": "HealthIcon" },
          "iconP2": { "type": "HealthIcon" },
          "startingSong": { "type": "Bool" },
          "generatedMusic": { "type": "Bool" },
          "curSong": { "type": "String" },
          "scripts": { "type": "ScriptPack" }
        }
      },
      "official": {
        "package": "funkin.play",
        "class": "PlayState",
        "file": "source/funkin/play/PlayState.hx",
        "access": "PlayState.instance",
        "fields": {
          "instance": { "type": "PlayState", "static": true },
          "currentSong": { "type": "Song" },
          "currentDifficulty": { "type": "String" },
          "currentVariation": { "type": "String" },
          "currentStage": { "type": "Null<Stage>" },
          "health": { "type": "Float" },
          "songScore": { "type": "Int" },
          "playbackRate": { "type": "Float" },
          "instrumentalVolume": { "type": "Float" },
          "playerVocalsVolume": { "type": "Float" },
          "opponentVocalsVolume": { "type": "Float" },
          "cameraFollowPoint": { "type": "FlxObject" },
          "deathCounter": { "type": "Int" }
        },
        "characterAccess": {
          "boyfriend": "currentStage.getBoyfriend():BaseCharacter",
          "dad": "currentStage.getDad():BaseCharacter",
          "girlfriend": "currentStage.getGirlfriend():BaseCharacter"
        },
        "notes": "Characters accessed via currentStage methods, not direct properties"
      }
    },

    "GameOverSubState": {
      "psych": {
