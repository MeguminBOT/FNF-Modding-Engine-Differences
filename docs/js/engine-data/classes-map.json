      "official": {
        "package": "funkin.play.song",
        "class": "Song",
        "file": "source/funkin/play/song/Song.hx",
        "notes": "Song is a rich class with metadata, chart data, variations support"
      }
    },

    "Stage": {
      "psych": {
        "package": "backend",
        "class": "BaseStage",
        "file": "source/backend/BaseStage.hx",
        "dataClass": "StageData",
        "dataFile": "source/backend/StageData.hx"
      },
      "codename": {
        "package": "funkin.game",
        "class": "Stage",
        "file": "source/funkin/game/Stage.hx",
        "notes": "XML-based stage definition, script-extensible"
      },
      "official": {
        "package": "funkin.play.stage",
        "class": "Stage",
        "file": "source/funkin/play/stage/Stage.hx",
        "scriptedClass": "ScriptedStage",
        "scriptedFile": "source/funkin/play/stage/ScriptedStage.hx"
      }
